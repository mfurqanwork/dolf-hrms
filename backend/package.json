{
  "name": "dolftech-hrms-backend",
  "private": true,
  "description": "Dolf HRMS API — Alembic migration scripts",
  "scripts": {
    "build": "python -m alembic upgrade head && python -m scripts.seed",
    "db:migrate": "node scripts/run-alembic.cjs upgrade head",
    "db:migrate:down": "node scripts/run-alembic.cjs downgrade -1",
    "db:current": "node scripts/run-alembic.cjs current",
    "db:history": "node scripts/run-alembic.cjs history --verbose",
    "db:check": "node scripts/run-alembic.cjs check",
    "db:revision": "node scripts/run-alembic.cjs revision --autogenerate -m",
    "db:stamp": "node scripts/run-alembic.cjs stamp head"
  }
}
